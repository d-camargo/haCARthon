# --- Telegram (obrigatório) ---
# Crie um bot com o @BotFather (/newbot) e cole o token. NUNCA versionar o real.
TELEGRAM_TOKEN=

# --- LLM (opcional; sem isto o bot usa o roteiro determinístico) ---
# Interface OpenAI-compatible (agnóstica de modelo).
OPENAI_API_KEY=
# Opcional: apontar para um modelo aberto/local (ex.: http://localhost:11434/v1 no Ollama)
OPENAI_BASE_URL=
# Opcional: modelo (default gpt-4o-mini)
LLM_MODEL=

# --- Demo ---
# cod_imovel real usado na demonstração (fica só aqui, no .env gitignored).
# Veja data/exemplo-raimundo.local.md. Qualquer entrada do usuário cai neste imóvel.
TERRA_DEMO_COD=
