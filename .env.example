# Exemplo de variáveis de ambiente — copie para .env e preencha localmente.
# NUNCA commitar o .env real (credenciais, CPFs e códigos SNCR ficam só no .env / fora do git).

# Ambiente de testes do SICAR (somente TESTE — nunca produção)
SICAR_TEST_BASE_URL=https://car-sus.dataprev.gov.br
SICAR_TEST_CPF=
SICAR_TEST_SNCR=
GOVBR_TEST_USER=
GOVBR_TEST_PASSWORD=

# Fontes de dados geoespaciais (registrar data de extração em data/README.md)
SICAR_WFS_URL=https://geoserver.car.gov.br/geoserver/sicar/wfs

# RER local (se rodar a pilha open source)
RER_BASE_URL=http://localhost
