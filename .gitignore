# Segredos — NUNCA versionar (credenciais, CPFs, códigos SNCR, mesmo de teste)
.env
.env.*
!.env.example
*.secret
docs/acesso-ambiente-testes.md

# Base documental (PDFs pesados) — ficam locais, indexados em docs/base-documental.md
*.pdf

# Dados geoespaciais pesados — registrar origem/data em data/README.md, não versionar
data/**
!data/README.md
!data/.gitkeep
*.shp
*.shx
*.dbf
*.geojson
*.gpkg
*.tif
*.tiff
*.zip

# Exceção: dados sintéticos pequenos da PoC (fazem parte da entrega, são versionados)
!src/poc-sobreposicao/dados/*.geojson
!src/poc-sobreposicao/saida/sobreposicoes.geojson
# Artefatos gerados da PoC que NÃO devem ser versionados
src/poc-sobreposicao/saida/*.sqlite
# Bancos SQLite em qualquer lugar (ex.: desafio-2/.../saida/poc.sqlite) — nunca versionar
*.sqlite

# Sistema operacional / editores
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Dependências / build
node_modules/
dist/
target/
__pycache__/
*.pyc
.venv/
venv/
